# =============================================================================
# OmniPresence Engine — environment template
# Copy to `.env.local` (local dev) or set these in your Vercel/Railway project.
# Visit /api/health and Settings → Setup after deploy to see what's configured.
#
# Tiers:
#   [REQUIRED]    app will not function without it
#   [LIVE DATA]   needed to deliver REAL (non-demo) results — set at least one SERP + one AI key
#   [RECOMMENDED] strongly advised for production
#   [OPTIONAL]    unlocks a specific integration; safe to leave blank
# =============================================================================

# -----------------------------------------------------------------------------
# Core — Supabase (auth + database)  [REQUIRED]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose to client

# Public base URL — used for OAuth redirects, email links, embed snippets  [REQUIRED]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for signing OAuth state (GSC/Bing/GA4). 32+ random chars.  [REQUIRED]
OAUTH_STATE_SECRET=replace-with-a-long-random-string

# Encrypts saved CMS/social credentials (AES-256-GCM). 32+ chars.  [REQUIRED in prod]
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-string

# -----------------------------------------------------------------------------
# Live data — SERP / rankings  (set at least ONE)  [LIVE DATA]
# Serper has a free tier and is the easiest start. Brave is an alternative.
# OmniData is your self-hosted, keyless data engine (see services/omnidata).
# -----------------------------------------------------------------------------
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Self-hosted OmniData engine (optional — replaces paid SERP/backlink vendors)
OMNIDATA_BASE_URL=
OMNIDATA_API_KEY=
OMNIDATA_SIGNING_SECRET=
# Common Crawl webgraph release id for the monthly backlink/authority re-ingest.
# Find the latest at https://commoncrawl.org/web-graphs (e.g. cc-main-2024-aug-sep-oct).
# Leave blank to disable the scheduled re-ingest (no release id is ever guessed).
COMMONCRAWL_WEBGRAPH_RELEASE=

# Paid SERP/keyword vendor fallback (optional)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# -----------------------------------------------------------------------------
# Live data — AI visibility  (set at least ONE)  [LIVE DATA]
# Used to measure whether ChatGPT/Claude/Gemini mention your brand.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Perplexity Sonar — real AI citations with source URLs (grounded)  [OPTIONAL]
PERPLEXITY_API_KEY=

# How many times each AI prompt is sampled (variance-aware). Default 3.
VISIBILITY_SAMPLE_RUNS=3

# --- LLM / paid-API COST GUARD (protects your provider bill) ---------------
# Hard spend ceilings enforced across ALL callers (scans, public audits, crons).
# When a ceiling is hit, paid LLM calls cleanly degrade to "unavailable" — never
# a crash, never a fake zero, never a surprise bill. Tune these to your comfort.
LLM_DAILY_BUDGET_USD=5          # est. max paid-LLM spend per day (0 = no daily cap)
LLM_MONTHLY_BUDGET_USD=50       # est. max paid-LLM spend per month (0 = no cap)
LLM_MAX_CALLS_PER_MIN=300       # per-instance runaway-loop circuit breaker (USD budget is the real cap)
LLM_MAX_OUTPUT_TOKENS=800       # output cap for short visibility probes
LLM_MAX_CONTENT_TOKENS=8192     # output cap for long-form generation (blogs, rewrites)
# LLM_BUDGET_DISABLED=true      # bypass the guard entirely (NOT recommended)

# Grounded AI UI-surface capture (headless browser microservice)  [OPTIONAL]
# Measures the real ChatGPT/Perplexity UI, not just the base-model API.
ENABLE_AI_UI_CAPTURE=false
AI_UI_CAPTURE_URL=
AI_UI_CAPTURE_KEY=

# -----------------------------------------------------------------------------
# Background jobs — Inngest (scans, crons, publish scheduler)  [RECOMMENDED]
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# OAuth — Google (GSC + GA4) and Bing Webmaster  [RECOMMENDED]
# Free, refund-proof ground truth: real impressions/clicks/CTR/position.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=

# Bing Webmaster API (URL submission + indexing)  [OPTIONAL]
BING_WEBMASTER_API_KEY=
BING_SITE_URL=

# -----------------------------------------------------------------------------
# Indexing & performance  [OPTIONAL]
# -----------------------------------------------------------------------------
INDEXNOW_KEY=
BING_INDEXNOW_KEY=
PAGESPEED_API_KEY=          # free Google key — improves Core Web Vitals/CrUX data

# -----------------------------------------------------------------------------
# Content scraping  [OPTIONAL]
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=          # falls back to keyless Cheerio fetch if unset

# -----------------------------------------------------------------------------
# Community / brand mentions — Reddit API (read-only)  [OPTIONAL]
# Falls back to keyless site:reddit.com SERP if unset.
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:omnipresence-engine:v1.0 (by /u/your-username)

# -----------------------------------------------------------------------------
# Attribution  [OPTIONAL]
# -----------------------------------------------------------------------------
PLAUSIBLE_API_URL=https://plausible.io/api/v1/stats
CLEARBIT_REVEAL_KEY=        # visitor de-anonymization (enriches beacon sessions)

# -----------------------------------------------------------------------------
# Distribution / social scheduling  [OPTIONAL]
# -----------------------------------------------------------------------------
AYRSHARE_API_KEY=
BUFFER_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Transactional email — Resend (audit leads + weekly reports)  [OPTIONAL]
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@yourdomain.com

# -----------------------------------------------------------------------------
# Billing — Stripe  [OPTIONAL when FREE_ACCESS_MODE=true]
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_AUDIT=price_audit
STRIPE_PRICE_TRACKING=price_tracking
STRIPE_PRICE_AGENCY=price_agency

# Set true to run the whole platform without Stripe (all features unlocked).
FREE_ACCESS_MODE=true

# -----------------------------------------------------------------------------
# Product analytics — PostHog  [OPTIONAL]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# 100X free / keyless data moat  [OPTIONAL — graceful fallback when unset]
# Every tool below is free or open-source. Missing tokens degrade to
# `unavailable` (never a fake zero), preserving refund-safety provenance.
# =============================================================================

# Phase 8 — self-hosted keyless SERP + open-model AI (Railway services)
SEARXNG_URL=                # e.g. http://searxng:8080 — keyless meta-search SERP source
OLLAMA_BASE_URL=            # e.g. http://ollama:11434 — open-model AI visibility (Llama/Mistral/Qwen)
OLLAMA_MODEL=llama3.1       # default open model pulled into Ollama

# Phase 1 — Microsoft Clarity behavioral analytics (free)
# Per-project token is stored encrypted in the credential vault; this is an
# optional org-wide default for the Clarity Data Export API.
CLARITY_API_TOKEN=

# Phase 6 — Video SEO (YouTube Data API v3, free quota)
YOUTUBE_API_KEY=

# Phase 7 — Core Web Vitals history (Chrome UX Report History API, free key)
# Falls back to PAGESPEED_API_KEY if unset (enable the CrUX API on the key).
CRUX_API_KEY=

# Phase 9 — first-party analytics (self-hosted PostHog, GA4-free)
POSTHOG_API_KEY=            # personal API key for the PostHog Query API (read)
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com

# Phase 12 — content quality / editorial QA (self-hosted LanguageTool, free)
LANGUAGETOOL_URL=           # e.g. http://languagetool:8010 — grammar/style scoring

# Optional self-hosted Langfuse (MIT) mirror for AEO prompt observability.
# Supabase stays the source of truth; this just mirrors probe traces for ops/eval.
LANGFUSE_BASE_URL=          # e.g. http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Measured GEO rewrite loop (AutoGEO, MIT). Days to wait before re-probing to
# measure citation lift, and whether to route rewrites through AutoGEO-Mini on
# Ollama (keyless) instead of the default ai-gateway LLMs.
GEO_REWRITE_WAIT_DAYS=7
GEO_REWRITE_USE_OLLAMA=     # "true" to use AutoGEO-Mini via Ollama

# Phase 14 — social & community mention firehose (free tokens raise rate limits)
PRODUCTHUNT_TOKEN=
GITHUB_TOKEN=
STACKEXCHANGE_KEY=
MASTODON_INSTANCE=https://mastodon.social   # keyless public hashtag timeline

# Phase 15 — entity & knowledge graph (Google Knowledge Graph Search, free key)
GOOGLE_KG_API_KEY=

# -----------------------------------------------------------------------------
# Phase 24 — Sovereign 200x Machine (manifest v24)
# -----------------------------------------------------------------------------
# Zero-Paid-Keys mode: when "true", the provider router drops every paid vendor
# and the claims harness auto-downgrades any claim that loses keyless backing.
# Prove it with `npm run audit:zero-paid-keys`.
ZERO_PAID_KEYS=             # "true" to run fully sovereign (no paid keys)

# Wave C — grounded AI UI capture microservice (services/ai-ui-capture).
ENABLE_AI_UI_CAPTURE=       # "true" to wire real ChatGPT/Perplexity/AI-Overview capture
AI_UI_CAPTURE_URL=          # e.g. https://ai-ui-capture.internal
AI_UI_CAPTURE_TOKEN=        # bearer/HMAC secret shared with the service

# Wave I — keyless SERP at scale.
SEARXNG_URLS=               # comma-separated SearXNG instances (failover); SEARXNG_URL still works
OMNIDATA_PROXIES=           # comma-separated proxy URLs for the Playwright SERP scraper (round-robin)

# Wave J — sovereign AI generation (open models). OLLAMA_BASE_URL / OLLAMA_MODEL
# are defined above in the keyless data-moat block.
# Generation routing: by DEFAULT paid frontier LLMs are tried FIRST (quality-first)
# whenever their keys are present, so customer-facing copy uses the best model.
# Set GENERATION_SOVEREIGN_FIRST=true to prefer free Ollama first and upgrade to a
# paid LLM only when the quality gate fails (cost-saver). ZERO_PAID_KEYS forces
# sovereign-only regardless.
GENERATION_SOVEREIGN_FIRST=    # "true" = prefer free Ollama first (cost-saver); default is paid-first

# Wave K — sovereign transactional email via self-hosted SMTP (Resend optional).
# Configure SPF/DKIM/DMARC on the From domain for deliverability.
EMAIL_FROM=                 # default From address (falls back to RESEND_FROM_EMAIL)
SMTP_HOST=                  # e.g. mail.yourdomain.com (Postfix/Maddy/etc.)
SMTP_PORT=587
SMTP_SECURE=                # "true" for implicit TLS (port 465)
SMTP_USER=
SMTP_PASS=
SMTP_DKIM_DOMAIN=           # signing domain, e.g. yourdomain.com
SMTP_DKIM_SELECTOR=         # e.g. default
SMTP_DKIM_PRIVATE_KEY=      # PEM private key (use \n for newlines)

# Wave K — direct social posting (no Buffer/Ayrshare middleman).
X_ACCESS_TOKEN=             # X/Twitter OAuth2 user token with tweet.write
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=        # e.g. urn:li:person:xxxx or urn:li:organization:xxxx

# Phase 24.1 — live provider benchmark (/api/admin/provider-benchmark).
# Bearer secret to call the benchmark endpoint in production (dev/localhost is
# open when unset). Falls back to OMNIDATA_SIGNING_SECRET if not provided.
BENCHMARK_SECRET=

# -----------------------------------------------------------------------------
# Demo mode  [DEV ONLY]
# Never set FORCE_DEMO_MODE=true in production — it is a deploy blocker.
# Paid orgs always receive real engine output regardless of this flag.
# -----------------------------------------------------------------------------
# FORCE_DEMO_MODE=false
