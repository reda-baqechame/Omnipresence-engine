# =============================================================================
# OmniPresence Engine — environment template
# Copy to `.env.local` (local dev) or set these in your Vercel project settings.
# Visit /api/health and Settings → Setup after deploy to see what's configured.
#
# Tiers:
#   [REQUIRED]    app will not function without it
#   [LIVE DATA]   needed to deliver REAL (non-demo) results — set at least one SERP + one AI key
#   [RECOMMENDED] strongly advised for production
#   [OPTIONAL]    unlocks a specific integration; safe to leave blank
# =============================================================================

# -----------------------------------------------------------------------------
# Core — Supabase (auth + database)  [REQUIRED]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose to client

# Public base URL — used for OAuth redirects, email links, embed snippets  [REQUIRED]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for signing OAuth state (GSC/Bing/GA4). 32+ random chars.  [REQUIRED]
OAUTH_STATE_SECRET=replace-with-a-long-random-string

# Encrypts saved CMS/social credentials (AES-256-GCM). 32+ chars.  [REQUIRED in prod]
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-string

# -----------------------------------------------------------------------------
# Live data — SERP / rankings  (set at least ONE)  [LIVE DATA]
# Serper has a free tier and is the easiest start. Brave is an alternative.
# OmniData is your self-hosted, keyless data engine (see services/omnidata).
# -----------------------------------------------------------------------------
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Self-hosted OmniData engine (optional — replaces paid SERP/backlink vendors)
OMNIDATA_BASE_URL=
OMNIDATA_API_KEY=
OMNIDATA_SIGNING_SECRET=

# Paid SERP/keyword vendor fallback (optional)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# -----------------------------------------------------------------------------
# Live data — AI visibility  (set at least ONE)  [LIVE DATA]
# Used to measure whether ChatGPT/Claude/Gemini mention your brand.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Perplexity Sonar — real AI citations with source URLs (grounded)  [OPTIONAL]
PERPLEXITY_API_KEY=

# How many times each AI prompt is sampled (variance-aware). Default 3.
VISIBILITY_SAMPLE_RUNS=3

# Grounded AI UI-surface capture (headless browser microservice)  [OPTIONAL]
# Measures the real ChatGPT/Perplexity UI, not just the base-model API.
ENABLE_AI_UI_CAPTURE=false
AI_UI_CAPTURE_URL=
AI_UI_CAPTURE_KEY=

# -----------------------------------------------------------------------------
# Background jobs — Inngest (scans, crons, publish scheduler)  [RECOMMENDED]
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# OAuth — Google (GSC + GA4) and Bing Webmaster  [RECOMMENDED]
# Free, refund-proof ground truth: real impressions/clicks/CTR/position.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=

# Bing Webmaster API (URL submission + indexing)  [OPTIONAL]
BING_WEBMASTER_API_KEY=
BING_SITE_URL=

# -----------------------------------------------------------------------------
# Indexing & performance  [OPTIONAL]
# -----------------------------------------------------------------------------
INDEXNOW_KEY=
BING_INDEXNOW_KEY=
PAGESPEED_API_KEY=          # free Google key — improves Core Web Vitals/CrUX data

# -----------------------------------------------------------------------------
# Content scraping  [OPTIONAL]
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=          # falls back to keyless Cheerio fetch if unset

# -----------------------------------------------------------------------------
# Community / brand mentions — Reddit API (read-only)  [OPTIONAL]
# Falls back to keyless site:reddit.com SERP if unset.
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:omnipresence-engine:v1.0 (by /u/your-username)

# -----------------------------------------------------------------------------
# Attribution  [OPTIONAL]
# -----------------------------------------------------------------------------
PLAUSIBLE_API_URL=https://plausible.io/api/v1/stats
CLEARBIT_REVEAL_KEY=        # visitor de-anonymization (enriches beacon sessions)

# -----------------------------------------------------------------------------
# Distribution / social scheduling  [OPTIONAL]
# -----------------------------------------------------------------------------
AYRSHARE_API_KEY=
BUFFER_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Transactional email — Resend (audit leads + weekly reports)  [OPTIONAL]
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@yourdomain.com

# -----------------------------------------------------------------------------
# Billing — Stripe  [OPTIONAL when FREE_ACCESS_MODE=true]
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_AUDIT=price_audit
STRIPE_PRICE_TRACKING=price_tracking
STRIPE_PRICE_AGENCY=price_agency

# Set true to run the whole platform without Stripe (all features unlocked).
FREE_ACCESS_MODE=true

# -----------------------------------------------------------------------------
# Product analytics — PostHog  [OPTIONAL]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Demo mode  [DEV ONLY]
# Never set FORCE_DEMO_MODE=true in production — it is a deploy blocker.
# Paid orgs always receive real engine output regardless of this flag.
# -----------------------------------------------------------------------------
# FORCE_DEMO_MODE=false
