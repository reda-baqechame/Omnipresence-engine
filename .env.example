# Free access (default: true — all features unlocked, billing disabled)
FREE_ACCESS_MODE=true

# Force demo/synthetic data even when API keys exist (optional)
# FORCE_DEMO_MODE=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PresenceOS

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_AUDIT=price_audit_one_time
STRIPE_PRICE_TRACKING=price_tracking_monthly
STRIPE_PRICE_AGENCY=price_agency_monthly

# AI Gateway / Providers
AI_GATEWAY_API_KEY=your-ai-gateway-key
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# Data Providers
DATAFORSEO_LOGIN=your-login
DATAFORSEO_PASSWORD=your-password
PERPLEXITY_API_KEY=pplx-...
FIRECRAWL_API_KEY=fc-...

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reports@presenceos.app

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Social scheduling (Phase 4)
AYRSHARE_API_KEY=
BUFFER_ACCESS_TOKEN=

# IndexNow
INDEXNOW_KEY=presenceos-key

# Plausible Analytics (Phase 6)
PLAUSIBLE_API_KEY=
PLAUSIBLE_API_URL=https://plausible.io/api/v1/stats

# OAuth (Phase 6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=

# OAuth state signing (use a random 32+ char secret in production)
OAUTH_STATE_SECRET=
