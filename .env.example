# OmniPresence Engine — Environment Template
# Copy to .env.local and fill values. Never commit .env.local.

# --- Required ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OAUTH_STATE_SECRET=generate-a-random-32-char-string-minimum

# --- Production security (required before saving CMS/social integrations) ---
INTEGRATION_ENCRYPTION_KEY=generate-a-random-32-char-string-minimum

# --- Live data (minimum: one SERP + one LLM) ---
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=

# --- OmniData self-hosted engine (recommended production) ---
OMNIDATA_BASE_URL=http://localhost:8787
OMNIDATA_API_KEY=
OMNIDATA_SIGNING_SECRET=

# --- Background jobs ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Email ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Indexing ---
INDEXNOW_KEY=
BING_WEBMASTER_API_KEY=
BING_SITE_URL=

# --- OAuth (GSC, GA4, Bing) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=

# --- Social distribution ---
AYRSHARE_API_KEY=
BUFFER_ACCESS_TOKEN=

# --- Billing (optional when FREE_ACCESS_MODE=true) ---
FREE_ACCESS_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_AUDIT=
STRIPE_PRICE_TRACKING=
STRIPE_PRICE_AGENCY=

# --- Optional paid boost ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Community mentions (real Reddit API; Quora + Reddit via SERP; HN via Algolia) ---
# Hacker News mentions are keyless (Algolia HN Search). Reddit API is optional
# and only adds richer full-text coverage.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Phase 11: The Free Data Moat (all keyless / open-source, no keys required) ---
# Google Trends demand index, tech-stack fingerprints, relative Popularity Index,
# unified Authority Rating, Wikipedia/Wikidata entity presence, and Hacker News
# mentions all work with NO API keys. They route through OmniData when deployed
# (recommended for caching + OpenPageRank), else fall back to direct keyless calls.
# REDDIT_USER_AGENT=web:omnipresence-engine:v1.0 (by /u/yourname)

# --- Real backlinks / keyword data (configured on the OmniData host) ---
# OmniData service env (see services/omnidata/.env.example):
#   OPENPAGERANK_API_KEY      real domain rating
#   GOOGLE_ADS_*              real keyword volume/CPC (Keyword Planner)
#   WEBGRAPH_DB_PATH          Common Crawl webgraph DuckDB index
#   OMNIDATA_ENABLE_SCRAPE    keyless Playwright SERP fallback (off by default)

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=

# --- Demo override ---
# FORCE_DEMO_MODE=true
