# ai-ui-capture service configuration.
# Generate strong secrets, e.g.  openssl rand -hex 32

# Bearer key the app sends as Authorization: Bearer <key>. REQUIRED in prod.
AI_UI_CAPTURE_KEY=dev-local-key

# Optional: separate HMAC signing secret for signed requests
# (x-aiuicapture-signature + x-aiuicapture-timestamp). Defaults to the API key.
AI_UI_CAPTURE_SIGNING_SECRET=

# Port to listen on.
PORT=8788

# Browser behavior.
AI_UI_CAPTURE_HEADFUL=false
AI_UI_CAPTURE_TIMEOUT_MS=45000

# Path to a Playwright storageState JSON with a logged-in ChatGPT/Gemini session.
# Without it, chatgpt/gemini captures return 204 (we never fake a logged-out view).
AI_UI_CAPTURE_STORAGE_STATE=
