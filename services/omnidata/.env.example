# --- Core ---
OMNIDATA_API_KEY=dev-local-key
OMNIDATA_SIGNING_SECRET=
REDIS_URL=redis://127.0.0.1:6379
PORT=8787

# --- SERP / search providers (any one enables real SERP) ---
SERPER_API_KEY=
BING_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- Keyless SERP/Maps fallback (OFF by default; needs Chromium) ---
OMNIDATA_ENABLE_SCRAPE=false
# OMNIDATA_SCRAPE_UA=

# --- JS-rendered crawl depth (SPA coverage, Katana-equivalent via Chromium) ---
# OFF by default. When true, on_page/crawl renders pages with the bundled
# Chromium before extracting links/content; falls back to static fetch if
# Chromium is unavailable. Per-request override: POST { js_render: true }.
OMNIDATA_ENABLE_JS_CRAWL=false

# --- Backlinks: real domain rating + Common Crawl webgraph index ---
OPENPAGERANK_API_KEY=
WEBGRAPH_DB_PATH=./data/webgraph.duckdb

# --- Embeddings / clustering (keyless, transformers.js) ---
# Default is the small, fast all-MiniLM-L6-v2. For sharper intent clusters and
# multilingual coverage, upgrade to BGE-M3 (MIT) — larger (~2GB) so size memory.
# EMBEDDINGS_MODEL=Xenova/all-MiniLM-L6-v2
# EMBEDDINGS_MODEL=Xenova/bge-m3

# --- Keywords: real volume/CPC via Google Ads Keyword Planner (OAuth) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_API_VERSION=v18
# GOOGLE_ADS_GEO=geoTargetConstants/2840
# GOOGLE_ADS_LANGUAGE=languageConstants/1000
