{
  "name": "@presenceos/omnidata",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "parity": "node --import tsx --test src/__tests__/parity.test.ts",
    "worker": "tsx src/worker.ts",
    "webgraph:ingest": "tsx src/cli/webgraph-ingest.ts"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "cheerio": "^1.2.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@duckdb/node-api": "^1.2.0-alpha.15",
    "@huggingface/transformers": "^3.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
